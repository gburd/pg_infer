{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "groupName": "rust dependencies",
      "groupSlug": "rust-deps",
      "matchUpdateTypes": ["minor", "patch"],
      "schedule": ["before 9am on monday"]
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["major"],
      "enabled": true,
      "schedule": ["before 9am on monday"]
    }
  ],
  "cargo": {
    "enabled": true
  }
}
